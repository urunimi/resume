{
  "name": "resume",
  "version": "1.0.0",
  "private": true,
  "description": "Resume as code with auto-translation via Claude API",
  "type": "module",
  "config": {
    "theme": "jsonresume-theme-macchiato",
    "languages": [
      "ko",
      "en"
    ],
    "site": "me.hovans.com"
  },
  "scripts": {
    "translate": "node scripts/translate.js",
    "build:pdf": "node scripts/build-pdf.js",
    "build:html": "node scripts/build-html.js",
    "build:site": "npm run build:pdf && npm run build:html",
    "build": "npm run translate -- --force && npm run build:site",
    "validate": "resumed validate resume.ko.json"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.9.0",
    "jsonresume-theme-macchiato": "^1.1.0",
    "puppeteer": "^23.0.0",
    "resumed": "^3.0.1"
  }
}
