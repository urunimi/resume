{
  "name": "resume",
  "version": "1.0.0",
  "private": true,
  "description": "Resume as code with auto-translation via Claude API",
  "type": "module",
  "config": {
    "theme": "jsonresume-theme-even",
    "languages": [
      "ko",
      "en"
    ]
  },
  "scripts": {
    "translate": "node scripts/translate.js",
    "build:pdf": "node scripts/build-pdf.js",
    "build": "npm run translate && npm run build:pdf",
    "validate": "resumed validate resume.ko.json"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.9.0",
    "jsonresume-theme-even": "^0.22.0",
    "puppeteer": "^23.0.0",
    "resumed": "^3.0.1"
  }
}
